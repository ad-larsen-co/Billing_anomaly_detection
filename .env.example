# Copy to .env and fill values. Never commit real secrets.

# OpenAI (required for Solver RAG and NLP)
OPENAI_API_KEY=sk-your-key-here

# Database: SQLite local default; use Postgres for production (see docker-compose.yml)
DATABASE_URL=sqlite:///./billing_anomaly.db

# Hugging Face Space (Gradio client uses this base URL)
HF_SPACE_URL=https://luca1028-anomaly-detector.hf.space

# MLflow local tracking
MLFLOW_TRACKING_URI=file:./mlruns

# Optional: disable OpenAI calls and return stubs (for CI without keys)
USE_MOCK_AI=true
